# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_password
POSTGRES_DB=inventory_db

# ── Backend ────────────────────────────────────────────────────────────────
# Used by the backend service to connect to the database.
# The hostname "db" is the Docker Compose service name.
DATABASE_URL=postgresql://inventory_user:inventory_password@db:5432/inventory_db

# ── Frontend ───────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend API.
# Keep this as localhost when running locally.
VITE_API_URL=http://localhost:8000
